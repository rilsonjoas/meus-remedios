APP_NAME=MeusRemedios
APP_ENV=production
APP_DEBUG=false
APP_URL=https://SEU-DOMINIO.railway.app

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR

LOG_CHANNEL=stderr
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=         # preencher com host do MySQL do Railway
DB_PORT=3306
DB_DATABASE=     # preencher
DB_USERNAME=     # preencher
DB_PASSWORD=     # preencher

SESSION_DRIVER=cookie
SESSION_LIFETIME=10080
SESSION_ENCRYPT=true

CACHE_STORE=database

SANCTUM_STATEFUL_DOMAINS=
FRONTEND_URL=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://SEU-DOMINIO.railway.app/api/auth/google/callback
